# LLM Provider: "gemini" (free, default), "groq" (free), or "anthropic"
XELSIUS_LLM_PROVIDER=gemini

# Gemini (free tier — aistudio.google.com)
GEMINI_API_KEY=AIza...
XELSIUS_GEMINI_MODEL=gemini-2.0-flash

# Groq (free tier — console.groq.com)
GROQ_API_KEY=gsk_...
XELSIUS_GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (for BYOK users or production)
ANTHROPIC_API_KEY=sk-ant-...
XELSIUS_MODEL=claude-haiku-4-5

# Rate limiting
XELSIUS_FREE_LIMIT=10
